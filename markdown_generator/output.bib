@inproceedings{waller_analysis_2023,
  title = {Analysis of {{Space Weathering Trends}} of {{Lunar Swirls}} in {{Highlands}} and {{Mare}}},
  booktitle = {55th {{Annual Meeting}} of the {{Division}} for {{Planetary Sciences}}},
  author = {Waller, Dany and Cahill, Joshua and Hendrix, Amanda and Retherford, Kurt and {Stockstill-Cahill}, Karen},
  year = 2023,
  month = oct,
  volume = {55},
  pages = {101.03},
  urldate = {2026-05-14},
  abstract = {Lunar swirls are photometric anomalies that are associated with magnetic anomalies, though not all lunar magnetic anomalies possess swirls. New models and maps of lunar magnetism lend insight into near-surface processes that may affect space weathering, such as solar wind standoff. Solar wind standoff is one proposed theory of swirl formation that has been indirectly observed, replicated experimentally, and modeled using different techniques. Under typical space weathering conditions, solar wind particles and micrometeoroids incident upon the lunar surface cause regolith maturation that manifests as brightening at the Lyman-{$\alpha$} wavelength (\textasciitilde 121.6 nm) and blueing of far-ultraviolet (FUV) spectral slopes (150-200 nm). The solar wind standoff theory suggests that the deflection of solar wind particles by some magnetic anomalies disrupts part of the space weathering process, forming photometric anomalies that appear optically immature compared to the surrounding regolith. The relationship between lunar swirls and their associated magnetic anomalies is complex, as near-surface field geometry, intensity, and relative solar wind exposure may influence the development of a photometric anomaly. The sensitivity of UV wavelengths to space weathering byproducts has been leveraged to analyze properties of swirls and the relationship of magnetic field geometry and intensity to UV reflectance [Hendrix et al., 2012; Hendrix et al., 2016; Waller et al., 2022]. Recent work indicates that space weathering trends may subtly differ for swirls found in the highlands versus swirls found in mare [Blewett et al., 2021a]. To further investigate this dichotomy and explore the sensitivity of UV wavelengths to submicroscopic iron (SMFe) particle abundances, five swirls and their associated magnetic anomalies were modeled and profiled using the methods of Waller et al. [2022]. In all five cases, the swirls were found to have sufficient magnetic geometry and intensity to potentially form miniature magnetospheres above the surface, even under typical compression from incident solar wind dynamic pressure. Initial results support the influence of regional composition on swirl expression, even when considering latitudinal trends in space weathering. UV wavelength observations compared to modeled SMFe particle abundances suggest that nanosize iron particle abundances may have the most profound effect on FUV reflectance of the swirls. Results from ongoing laboratory work to quantify UV wavelength sensitivity to maturity are used to interpret the profiles sampled across each swirl.},
  annotation = {ADS Bibcode: 2023DPS....5510103W}
}

@inproceedings{waller_designing_2024,
  title = {Designing a {{Network}} of {{Environmental Monitoring Stations}} to {{Combine Lunar Geophysics}} and {{Space Weather Investigations}}},
  booktitle = {{{AGU Fall Meeting Abstracts}}},
  author = {Waller, Dany and Rorschach, Katherine L. and Stautberg, Abigail M. and Cahill, Joshua T. and Izquierdo, Kris and Shea, Evan},
  year = 2024,
  month = dec,
  volume = {2024},
  pages = {P33I-08},
  urldate = {2026-05-14},
  abstract = {Historically, lunar mission concepts have approached geophysical investigations and space weathering investigations separately. However, there are common measurement techniques of interest to both investigations such as magnetometry and gamma ray/neutron spectrometry. Both types of investigations would benefit from a long-lived "host" station that could support continuous operations over multiple lunar nights. Thermal limit advances made using existing hardware and novel developments in energy generation and storage technology are bringing the possibility of surviving the lunar night within reach for commercial components. The next goal will be surviving - and even operating - over many consecutive lunar nights. Here we propose an integrated network of stations to study the lunar interior and space weathering over multiple lunar nights. A baseline package of instruments is outlined within a modular network architecture, making each station location-agnostic with the option to curate hardware and sensors for areas of particular interest. Commercial components and science-grade sensors are blended to balance cost and performance. Novel thermal management and energy storage methods based on in-situ resource utilization are incorporated as part of the station design to not just survive, but operate continuously over multiple lunar nights. Illumination and thermal modeling results were used to determine common system requirements and simulated sensor observations were quantified to determine network efficiency. Future work is planned for laboratory testing of in-situ resource utilization concepts such as thermal banking in regolith and investigating potential methods of station deployment.},
  annotation = {ADS Bibcode: 2024AGUFMP33I...08W}
}

